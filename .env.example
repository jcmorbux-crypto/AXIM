########################################
# AXIM SYSTEM CONFIGURATION
########################################
# Copy this file to .env and fill in your own values.
# .env is gitignored - never commit real credentials.

AXIM_NAME=AXIM
VERSION=1.0.0

########################################
# ENVIRONMENT
########################################

TIMEZONE=America/Los_Angeles

########################################
# TELEGRAM
########################################
# From https://my.telegram.org -> API development tools

TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1XXXXXXXXXX

########################################
# SIGNAL SOURCES
########################################

# Allow-list for core/telegram_listener.py (the active live pipeline).
# Comma-separated; each entry matches a chat's @username (exact,
# case-insensitive) or its display title/first_name (case-insensitive
# substring). Empty = fail-closed, no chat is trusted. Can also be
# managed from the web UI's Signal Sources page instead of editing this
# file directly.
WATCH_CHANNELS=

########################################
# POCKET OPTION
########################################

# PO_EMAIL/PO_PASSWORD are NOT read by any code path today - login is
# handled by the persistent browser profile, authenticated once by hand
# (via the Broker Accounts UI or scripts/connect_broker_account.py).
# Left here as a placeholder for a possible future automated-login
# feature; setting these does not change which account AXIM logs into.
PO_EMAIL=YOUR_POCKET_OPTION_EMAIL
PO_PASSWORD=YOUR_POCKET_OPTION_PASSWORD
POCKET_URL=https://pocketoption.com

# Legacy global demo/live switch, still enforced by
# risk_manager.check_demo_only() as one of several independent safety
# layers - per-Fund/per-broker-account live_enabled (set from the UI) is
# the primary switch for which Pocket Option cabinet a given account
# actually uses. Leave this at DEMO unless you have deliberately decided
# to go live.
ACCOUNT=DEMO

# Only set if/when you have manually inspected your own live Pocket
# Option cabinet page and confirmed its DOM class - see
# docs/AXIM_LIVE_READINESS_CHECKLIST.md. Leave unset for demo-only use.
# LIVE_URL=
# LIVE_MODE_VERIFICATION_CLASS=

########################################
# EXECUTION
########################################

AUTO_EXECUTE=true
PREVIEW_ONLY=true
# Do NOT set ARMED=true here as a standing default. This is the master
# kill switch that lets a trade actually be clicked. Every test in this
# project that needed ARMED=true set it via an isolated process
# environment variable, never in a checked-in .env, except for
# deliberate, watched soak-test runs against ACCOUNT=DEMO. See
# docs/AXIM_LIVE_READINESS_CHECKLIST.md.
ARMED=false
DEFAULT_TRADE_AMOUNT=1
TRADE_AMOUNT=1
MINIMUM_PAYOUT=90
MAX_CONCURRENT_WORKERS=6
MAX_TRADE_AMOUNT=50
MAX_TRADES_PER_HOUR=10
MAX_CONSECUTIVE_LOSSES=3
COOLDOWN_AFTER_LOSS_SECONDS=60
DUPLICATE_SIGNAL_WINDOW_SECONDS=120
MAX_SIGNAL_AGE=10

# Drawdown circuit breaker - real net realized $ loss since local
# midnight, at or beyond which new signals are rejected. Catches a
# steady bleed-out through an alternating win/loss pattern that
# MAX_CONSECUTIVE_LOSSES alone cannot. Adjust to your own risk tolerance.
MAX_DAILY_LOSS=100

########################################
# API / REMOTE ACCESS
########################################
# Defaults are local-only. See docs/AXIM_REMOTE_ACCESS.md before changing
# these to allow a Remote Client to connect over Tailscale.

API_BIND_HOST=127.0.0.1
API_BIND_PORT=8090
ALLOWED_ORIGINS=

########################################
# STORAGE
########################################

DATABASE=data/axim.db
DATABASE_FILE=data/axim.db
LOG_DIRECTORY=logs
SESSION_DIRECTORY=sessions

########################################
# FEATURE MODULES
########################################

ENABLE_TELEGRAM=true
ENABLE_DISCORD=false
ENABLE_WHOP=false
ENABLE_WINIBLE=false
ENABLE_EMAIL=false
ENABLE_WEBHOOKS=false

########################################
# DASHBOARD
########################################

ENABLE_DASHBOARD=true
DASHBOARD_PORT=8080

########################################
# LOGGING
########################################

LOG_LEVEL=INFO
SAVE_SIGNALS=true
SAVE_RESULTS=true
SAVE_SCREENSHOTS=true

########################################
# DEVELOPMENT
########################################

DEBUG=false

# Logs every incoming Telegram message's routing decision (chat/sender/
# filter/parser) before any filtering - useful when tuning WATCH_CHANNELS.
# No effect on trading execution logic.
TELEGRAM_DEBUG_LOG=false
