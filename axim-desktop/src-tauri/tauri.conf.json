{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AXIM TradeStation",
  "version": "0.9.0-dev",
  "identifier": "com.axim.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AXIM TradeStation",
        "url": "index.html",
        "width": 1360,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "AXIM TradeStation",
    "copyright": "Copyright (c) AXIM TradeStation",
    "shortDescription": "Remote Client for AXIM TradeStation",
    "longDescription": "Monitor and control your AXIM TradeStation server - Mission Control, Funds, Trading Sessions, Strategy Lab, Automation Studio, and more - from this desktop app, whether AXIM runs on this machine or remotely over Tailscale.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
